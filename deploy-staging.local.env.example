# =============================================================================
# Bulk Edit App - STAGING provisioning secrets (TEMPLATE)
#
# scripts/prepare-staging-secrets.ps1 copies this to deploy-staging.local.env
# for you to fill. deploy-staging.local.env is GITIGNORED and must NEVER be
# committed or pasted into chat. Fill values, SAVE, then run provision-staging.ps1.
#
# Legend:  (required) blocks provisioning until set   (optional) may stay blank
#          STAGING/TEST ONLY = never use a production/live value here
# =============================================================================

# --- DigitalOcean (required) -------------------------------------------------
# Token: DO dashboard -> API -> Tokens -> Generate New Token.
# Minimum scopes: read + write (App Platform + Databases). STAGING ONLY.
DIGITALOCEAN_ACCESS_TOKEN=
DIGITALOCEAN_PROJECT_NAME=bulk-edit-staging
DIGITALOCEAN_REGION=nyc
DIGITALOCEAN_STAGING_BACKEND_APP_NAME=bulk-edit-staging-api
DIGITALOCEAN_STAGING_FRONTEND_APP_NAME=bulk-edit-staging-web
DIGITALOCEAN_STAGING_DB_NAME=bulk-edit-staging-db
DIGITALOCEAN_STAGING_REDIS_NAME=bulk-edit-staging-redis

# --- Cloudflare (required for DNS; Access optional) --------------------------
# Token: CF dashboard -> My Profile -> API Tokens -> Create Token.
# Minimum permissions: Zone:DNS:Edit + Zone:Read for bulkeditapp.com.
# For Cloudflare Access also add: Account:Access: Apps and Policies:Edit.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
# Comma-separated emails allowed through Cloudflare Access on staging (optional).
CLOUDFLARE_STAGING_ACCESS_ALLOWED_EMAILS=

# --- Domains / URLs (required, staging only) ---------------------------------
STAGING_DOMAIN=staging.bulkeditapp.com
API_STAGING_DOMAIN=api-staging.bulkeditapp.com
STAGING_FRONTEND_URL=https://staging.bulkeditapp.com
STAGING_BACKEND_URL=https://api-staging.bulkeditapp.com

# --- Backend secrets (auto-generated if left blank; NEVER printed) -----------
# provision-staging.ps1 fills these into THIS local file if empty:
#   JWT_SECRET      -> token_urlsafe(64)
#   ENCRYPTION_KEY  -> fresh Fernet key (MUST NOT equal the public CI dummy key)
JWT_SECRET=
ENCRYPTION_KEY=

# --- Stripe (optional, TEST MODE ONLY) ---------------------------------------
# If set, STRIPE_SECRET_KEY MUST start with sk_test_. sk_live_ is REFUSED.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Etsy (optional, dev/test app only or blank) -----------------------------
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# --- AI (optional; blank => AI_PROVIDER=mock; low-limit staging key only) -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Monitoring (optional) ---------------------------------------------------
SENTRY_DSN=

# =============================================================================
# HARD RULES enforced by provision-staging.ps1:
#   - Never use sk_live_ Stripe keys here.
#   - Never point at a production DB / Redis (those auto-wire from DO spec).
#   - Never use the public CI Fernet key
#     (uOv7K6PYL6v4G77O0WqJrA5BrM42x3NCAQZUSO2rTio=) for ENCRYPTION_KEY.
#   - Backend/Frontend URLs must contain "staging".
# =============================================================================
