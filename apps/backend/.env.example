ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Local dev (outside Docker): use host-mapped ports
DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@localhost:55432/bulkedit
REDIS_URL=redis://localhost:56379/0

# Inside Docker Compose: use service names and container ports
# DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@postgres:5432/bulkedit
# REDIS_URL=redis://redis:6379/0

FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:8100
BACKEND_CORS_ORIGINS=http://localhost:3100

# Production reference (www.bulkeditapp.com) — set in deployment secrets, not here:
# FRONTEND_URL=https://www.bulkeditapp.com
# BACKEND_URL=https://api.bulkeditapp.com
# BACKEND_CORS_ORIGINS=https://www.bulkeditapp.com,https://bulkeditapp.com
# ETSY_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/etsy/callback
# PINTEREST_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/pinterest/callback
# INSTAGRAM_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/instagram/callback
