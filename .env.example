# ─────────────────────────────────────────────
# Bulk-Edit — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to git.
#
# Default host port mapping:
#   frontend  → 3100:3000
#   backend   → 8100:8000
#   postgres  → internal Docker only (not exposed to host)
#   redis     → internal Docker only (not exposed to host)
#
# To expose postgres/redis on host ports for direct DB access,
# use docker-compose.dev-ports.yml (see file for instructions).
# ─────────────────────────────────────────────

# ── Docker Compose ────────────────────────────
COMPOSE_PROJECT_NAME=bulk-edit

# ── Environment ───────────────────────────────
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────
# Docker Compose (inside containers): use service name + container port
DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@postgres:5432/bulkedit
# Local dev (outside Docker): use docker-compose.dev-ports.yml to expose host port, then:
# DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@localhost:55432/bulkedit

# ── Redis ─────────────────────────────────────
# Docker Compose: use service name + container port
REDIS_URL=redis://redis:6379/0
# Local dev (outside Docker): use docker-compose.dev-ports.yml to expose host port, then:
# REDIS_URL=redis://localhost:56379/0

# ── JWT Auth ──────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-minimum-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App URLs ──────────────────────────────────
FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:8100
BACKEND_CORS_ORIGINS=http://localhost:3100

# ── Frontend (Next.js public vars) ────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_BASIC_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_BASIC_YEARLY=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_ME

# ── Etsy OAuth ────────────────────────────────
# Backend callback route (verified in code: app/api/v1/etsy.py -> /api/v1/etsy/callback).
# Register this exact URL in the Etsy Developer Portal.
ETSY_CLIENT_ID=REPLACE_ME
ETSY_CLIENT_SECRET=REPLACE_ME
ETSY_REDIRECT_URI=http://localhost:8100/api/v1/etsy/callback

# ── AI Providers ──────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── S3 / Object Storage ───────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=bulkedit-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Email (for verification / password reset) ─
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
EMAIL_FROM=noreply@bulk-edit.com

# ── Encryption (for Etsy token encryption) ────
ENCRYPTION_KEY=change-me-to-a-32-byte-fernet-key-base64-encoded

# ── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Sentry (optional) ─────────────────────────
SENTRY_DSN=

# ── Video Generator ───────────────────────────
# Set VIDEO_RENDERER_ENABLED=true once Docker has ffmpeg available.
# ffmpeg is installed in the backend Dockerfile by default.
VIDEO_RENDERER_ENABLED=false
# Override ffmpeg binary path only if needed (default: ffmpeg on PATH).
FFMPEG_PATH=
# Override output directory for rendered MP4 files (default: /tmp/video_renders).
VIDEO_OUTPUT_DIR=

# ── Pinterest Integration ─────────────────────
# Create a Pinterest app at developers.pinterest.com.
# Set callback URL in your Pinterest app to match PINTEREST_REDIRECT_URI.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8100/api/v1/promote/pinterest/callback

# ── Instagram / Meta Integration ─────────────
# Create a Meta app at developers.facebook.com.
# Add Instagram Basic Display or Instagram Graph API product.
# Instagram publishing requires a Business or Creator account linked to a Facebook Page.
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8100/api/v1/promote/instagram/callback

# ─────────────────────────────────────────────
# PRODUCTION REFERENCE (www.bulkeditapp.com)
# ─────────────────────────────────────────────
# Do NOT use these locally. Copy into the deployment platform's secret store.
# Domain model:
#   Frontend : https://www.bulkeditapp.com
#   Root     : https://bulkeditapp.com  -> redirects to https://www.bulkeditapp.com
#   Backend  : https://api.bulkeditapp.com
#
# ENVIRONMENT=production
# DEBUG=false
#
# App URLs
# FRONTEND_URL=https://www.bulkeditapp.com
# BACKEND_URL=https://api.bulkeditapp.com
# BACKEND_CORS_ORIGINS=https://www.bulkeditapp.com,https://bulkeditapp.com
# NEXT_PUBLIC_APP_URL=https://www.bulkeditapp.com
# NEXT_PUBLIC_BACKEND_URL=https://api.bulkeditapp.com
#
# OAuth / webhook callbacks (routes verified in code — register the exact URL with each provider)
# ETSY_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/etsy/callback
# PINTEREST_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/pinterest/callback
# INSTAGRAM_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/instagram/callback
# Stripe webhook endpoint (register in Stripe Dashboard):
#   https://api.bulkeditapp.com/api/v1/billing/webhook
