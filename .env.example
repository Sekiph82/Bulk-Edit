# ─────────────────────────────────────────────
# Bulk-Edit — Environment Variables Example
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Docker Compose: use postgres as host (service name)
# Local dev: use localhost
DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@localhost:5432/bulkedit
# DATABASE_URL=postgresql+asyncpg://bulkedit:bulkedit_password@postgres:5432/bulkedit

# ── Redis ─────────────────────────────────────
# Docker Compose: use redis as host (service name)
# Local dev: use localhost
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# ── JWT Auth ──────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-minimum-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App URLs ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_BASIC_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_BASIC_YEARLY=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_ME

# ── Etsy OAuth ────────────────────────────────
ETSY_CLIENT_ID=REPLACE_ME
ETSY_CLIENT_SECRET=REPLACE_ME
ETSY_REDIRECT_URI=http://localhost:8000/auth/etsy/callback

# ── AI Providers ──────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── S3 / Object Storage ───────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=bulkedit-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Email (for verification / password reset) ─
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
EMAIL_FROM=noreply@bulk-edit.com

# ── Encryption (for Etsy token encryption) ────
ENCRYPTION_KEY=change-me-to-a-32-byte-fernet-key-base64-encoded

# ── Backend CORS ──────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Bulk-Edit

# ── Environment ───────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Celery ────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Sentry (optional) ─────────────────────────
SENTRY_DSN=
