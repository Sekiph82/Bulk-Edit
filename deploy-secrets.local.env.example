# ─────────────────────────────────────────────────────────────────────────────
# Bulk-Edit — Guided production deploy secrets (TEMPLATE)
#
# Claude Code copies this to  deploy-secrets.local.env  for you to fill.
# deploy-secrets.local.env is gitignored and MUST NEVER be committed or pasted
# into chat. Fill the blanks below, SAVE, then press Continue/OK in Claude Code.
#
# Legend:
#   (required) — deploy will not run until this is filled
#   (optional) — leave blank; the related feature shows "unavailable" until set
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider API tokens ──────────────────────────────────────────────────────
# VERCEL_TOKEN        (required) Vercel → Account → Settings → Tokens → Create
# VERCEL_ORG_ID       (required for non-interactive deploy) Vercel project → Settings → General
# VERCEL_PROJECT_ID   (required for non-interactive deploy) Vercel project → Settings → General
# RENDER_API_KEY      (required) Render → Account Settings → API Keys
# RENDER_OWNER_ID     (optional) Render owner/team id (from GET /v1/owners)
# RENDER_SERVICE_ID   (required after the Render service exists — see docs)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_API_KEY=
RENDER_OWNER_ID=
RENDER_SERVICE_ID=

# ── Project names ────────────────────────────────────────────────────────────
VERCEL_PROJECT_NAME=bulk-edit
RENDER_SERVICE_NAME=bulk-edit-api

# ── Production domains ───────────────────────────────────────────────────────
FRONTEND_DOMAIN=www.bulkeditapp.com
APEX_DOMAIN=bulkeditapp.com
BACKEND_DOMAIN=api.bulkeditapp.com

# ── Vercel frontend env (public — safe to expose in browser bundle) ──────────
NEXT_PUBLIC_BACKEND_URL=https://api.bulkeditapp.com
NEXT_PUBLIC_APP_URL=https://www.bulkeditapp.com

# ── Render backend env (non-secret) ──────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
FRONTEND_URL=https://www.bulkeditapp.com
BACKEND_URL=https://api.bulkeditapp.com
BACKEND_CORS_ORIGINS=https://www.bulkeditapp.com,https://bulkeditapp.com

# ── Backend secrets (required) ───────────────────────────────────────────────
# JWT_SECRET      strong random string (64+ chars). Generate:
#                 python -c "import secrets; print(secrets.token_urlsafe(64))"
# ENCRYPTION_KEY  Fernet key (encrypts Etsy tokens). Generate:
#                 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET=
ENCRYPTION_KEY=

# ── Etsy (optional — Etsy connect disabled until filled) ─────────────────────
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/etsy/callback

# ── Stripe (optional — billing disabled until filled) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_YEARLY=

# ── Pinterest (optional) ─────────────────────────────────────────────────────
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/pinterest/callback

# ── Instagram / Meta (optional) ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.bulkeditapp.com/api/v1/promote/instagram/callback

# ── AI (optional — defaults to mock provider) ────────────────────────────────
AI_PROVIDER=mock
OPENAI_API_KEY=

# ── Email (optional — contact form / transactional mail) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_FROM_EMAIL=noreply@bulkeditapp.com
CONTACT_TO_EMAIL=support@bulkeditapp.com

# ── Video (optional) ─────────────────────────────────────────────────────────
VIDEO_RENDERER_ENABLED=false
FFMPEG_PATH=ffmpeg
VIDEO_OUTPUT_DIR=/tmp/video_renders

# ── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
