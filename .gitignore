# Environment
.env
.env.local
.env.*.local
*.env

# Guided-deploy local secrets (NEVER commit — example is the only tracked one)
deploy-secrets.local.env
deploy-secrets.*.env
!deploy-secrets.local.env.example

# Vercel CLI local link/state
.vercel/

# Guided-deploy generated output (may contain secrets — local only)
scripts/output/*
!scripts/output/.gitkeep

# Staging provisioning local secrets (NEVER commit; example is the only tracked one)
deploy-staging.local.env
*.local.env
!*.local.env.example
*secrets*.env
.doctl/
.cloudflared/
cloudflare-token*
digitalocean-token*

# Local superuser seed (never commit real credentials)
apps/backend/.local-superusers.env
.local-superusers.env
*.local-superusers.env

# Staging admin/test user temporary passwords (never commit real credentials)
*.local.txt

